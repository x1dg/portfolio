---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <style is:global>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      :root {
        --bg: #0a0a0f;
        --bg-secondary: #12121a;
        --fg: #e6edf3;
        --fg-muted: #8b949e;
        --accent: #ff6b2b;
        --accent-dim: #cc4400;
        --border: #2a2a35;
        --terminal-green: #ff8c42;
        --terminal-green-dim: #ff6b2b;
      }
      html {
        font-family: 'JetBrains Mono', 'Fira Code', 'Consolas', monospace;
        background: var(--bg);
        color: var(--fg);
        line-height: 1.6;
        font-size: 16px;
      }
      body {
        min-height: 100vh;
        background: 
          radial-gradient(ellipse at top, #1a1025 0%, #0a0a0f 50%),
          repeating-linear-gradient(
            0deg,
            transparent,
            transparent 2px,
            rgba(255, 107, 43, 0.02) 2px,
            rgba(255, 107, 43, 0.02) 4px
          );
      }
      ::selection {
        background: var(--accent);
        color: var(--bg);
      }
      a {
        color: var(--accent);
        text-decoration: none;
        transition: color 0.2s;
      }
      a:hover {
        color: var(--terminal-green);
        text-decoration: underline;
      }
      .container {
        max-width: 900px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
      }
      /* Terminal window */
      .terminal {
        background: var(--bg-secondary);
        border: 1px solid var(--border);
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 
          0 0 0 1px var(--border),
          0 8px 32px rgba(0, 0, 0, 0.4),
          inset 0 1px 0 rgba(255, 255, 255, 0.05);
      }
      .terminal-header {
        background: #15151f;
        border-bottom: 1px solid var(--border);
        padding: 0.75rem 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }
      .terminal-dots {
        display: flex;
        gap: 0.375rem;
      }
      .terminal-dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
      }
      .terminal-dot.close { background: #ff5f57; }
      .terminal-dot.minimize { background: #ffbd2e; }
      .terminal-dot.maximize { background: #28ca42; }
      .terminal-title {
        margin-left: 1rem;
        color: var(--fg-muted);
        font-size: 0.875rem;
        font-weight: 500;
      }
      .terminal-body {
        padding: 1.5rem;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.9rem;
        line-height: 1.7;
      }
      /* ASCII Banner */
      .ascii-banner {
        color: var(--terminal-green);
        font-size: 0.7rem;
        line-height: 1.1;
        white-space: pre;
        margin-bottom: 1.5rem;
        opacity: 0.9;
        font-family: 'Space Mono', monospace;
      }
      /* Prompt */
      .prompt-line {
        display: flex;
        align-items: baseline;
        gap: 0.5rem;
        margin-bottom: 0.5rem;
      }
      .prompt {
        color: var(--terminal-green);
        font-weight: 700;
      }
      .prompt-path {
        color: #58a6ff;
        font-weight: 500;
      }
      .command {
        color: var(--fg);
      }
      .command-output {
        color: var(--fg-muted);
        margin-left: 2rem;
        margin-bottom: 1rem;
      }
      .command-output strong {
        color: var(--fg);
      }
      .section-divider {
        color: var(--border);
        margin: 1.5rem 0;
        border: none;
        border-top: 1px solid var(--border);
      }
      /* Skills list */
      .skills-list {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 0.5rem;
        margin-top: 1rem;
      }
      .skill-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 0.75rem;
        background: rgba(255, 107, 43, 0.05);
        border: 1px solid var(--border);
        border-radius: 4px;
        transition: all 0.2s;
      }
      .skill-item:hover {
        border-color: var(--accent);
        background: rgba(255, 107, 43, 0.1);
      }
      .skill-bullet {
        color: var(--terminal-green);
      }
      /* Projects list */
      .project-item {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        padding: 1rem;
        border: 1px solid var(--border);
        border-radius: 6px;
        margin-bottom: 0.75rem;
        transition: all 0.2s;
        background: rgba(255, 255, 255, 0.02);
      }
      .project-item:hover {
        border-color: var(--accent);
        background: rgba(255, 107, 43, 0.03);
      }
      .project-perms {
        color: var(--fg-muted);
        font-size: 0.8rem;
        white-space: nowrap;
      }
      .project-meta {
        flex: 1;
      }
      .project-name {
        color: #58a6ff;
        font-weight: 600;
      }
      .project-desc {
        color: var(--fg-muted);
        font-size: 0.85rem;
        margin-top: 0.25rem;
      }
      .project-link {
        color: var(--accent);
        font-size: 0.85rem;
      }
      /* Contact links */
      .contact-links {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        margin-top: 1rem;
      }
      .contact-link {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.5rem 0.75rem;
        border: 1px solid var(--border);
        border-radius: 4px;
        transition: all 0.2s;
      }
      .contact-link:hover {
        border-color: var(--accent);
        background: rgba(255, 107, 43, 0.05);
      }
      .contact-label {
        color: var(--fg-muted);
        min-width: 100px;
      }
      .contact-value {
        color: var(--accent);
      }
      /* Blinking cursor */
      .cursor {
        display: inline-block;
        width: 8px;
        height: 1.2em;
        background: var(--terminal-green);
        margin-left: 2px;
        animation: blink 1s infinite;
        vertical-align: text-bottom;
      }
      @keyframes blink {
        0%, 50% { opacity: 1; }
        51%, 100% { opacity: 0; }
      }
      /* Loading animation */
      .loading {
        color: var(--fg-muted);
        font-style: italic;
      }
      /* Responsive */
      @media (max-width: 600px) {
        .container { padding: 1rem; }
        .terminal-body { padding: 1rem; font-size: 0.85rem; }
        .ascii-banner { font-size: 0.55rem; }
        .skills-list { grid-template-columns: 1fr; }
      }
      /* Reduced motion */
      @media (prefers-reduced-motion: reduce) {
        .cursor { animation: none; opacity: 1; }
        * { transition: none !important; }
      }

      /* === GLITCH EFFECT === */
      .ascii-banner {
        position: relative;
      }
      .ascii-banner:hover {
        animation: glitch 0.3s infinite;
      }
      .ascii-banner::before,
      .ascii-banner::after {
        content: attr(data-text);
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        opacity: 0;
      }
      .ascii-banner:hover::before {
        animation: glitch-layer 0.3s infinite;
        color: #ff0000;
        z-index: -1;
        opacity: 0.8;
      }
      .ascii-banner:hover::after {
        animation: glitch-layer 0.3s infinite reverse;
        color: #00ffff;
        z-index: -2;
        opacity: 0.8;
      }
      @keyframes glitch {
        0%, 100% { transform: translate(0); }
        20% { transform: translate(-2px, 2px); }
        40% { transform: translate(-2px, -2px); }
        60% { transform: translate(2px, 2px); }
        80% { transform: translate(2px, -2px); }
      }
      @keyframes glitch-layer {
        0%, 100% { transform: translate(0); clip-path: inset(0 0 0 0); }
        25% { transform: translate(3px, 0); clip-path: inset(20% 0 60% 0); }
        50% { transform: translate(-3px, 0); clip-path: inset(40% 0 30% 0); }
        75% { transform: translate(3px, 0); clip-path: inset(60% 0 10% 0); }
      }

      /* === SCANLINE === */
      .scanline {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 4px;
        background: linear-gradient(
          to bottom,
          transparent,
          rgba(255, 107, 43, 0.4),
          transparent
        );
        z-index: 1000;
        pointer-events: none;
        animation: scanline 4s linear infinite;
      }
      @keyframes scanline {
        0% { top: -4px; }
        100% { top: 100vh; }
      }

      /* === NAVIGATION === */
      .terminal-nav {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        padding: 1rem;
        background: var(--bg-secondary);
        border: 1px solid var(--border);
        border-radius: 6px;
        margin-bottom: 1rem;
      }
      .nav-link {
        padding: 0.5rem 1rem;
        color: var(--terminal-green);
        border: 1px solid var(--border);
        border-radius: 4px;
        font-size: 0.85rem;
        transition: all 0.2s;
        text-decoration: none !important;
      }
      .nav-link:hover {
        border-color: var(--accent);
        background: rgba(255, 107, 43, 0.1);
        color: var(--accent);
      }

      /* === BOOT SEQUENCE === */
      .boot-line {
        opacity: 0;
        transform: translateY(5px);
        transition: opacity 0.3s, transform 0.3s;
      }
      .boot-line.visible {
        opacity: 1;
        transform: translateY(0);
      }

      /* === PROGRESS BAR === */
      .progress-container {
        margin: 1rem 0;
        display: none;
      }
      .progress-container.visible {
        display: block;
      }
      .progress-bar {
        height: 20px;
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 4px;
        overflow: hidden;
        font-family: 'JetBrains Mono', monospace;
        font-size: 12px;
        line-height: 20px;
        color: var(--accent);
      }
      .progress-fill {
        height: 100%;
        background: var(--accent);
        width: 0%;
        transition: width 0.1s linear;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--bg);
        font-weight: bold;
      }
    </style>
  </head>
  <body>
    <div class="scanline"></div>
    <div class="container">
      <div class="terminal">
        <div class="terminal-header">
          <div class="terminal-dots">
            <span class="terminal-dot close"></span>
            <span class="terminal-dot minimize"></span>
            <span class="terminal-dot maximize"></span>
          </div>
          <span class="terminal-title">x1dg@portfolio:~$</span>
        </div>
        <div class="terminal-body">
          <slot />
        </div>
      </div>
      <p style="text-align: center; color: var(--fg-muted); font-size: 0.75rem; margin-top: 1.5rem;">
        Built with Astro, JetBrains Mono, and ☕ · <a href="https://github.com/x1dg" target="_blank" rel="noopener">Source</a>
      </p>
    </div>
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        // Boot sequence animation
        const bootLines = document.querySelectorAll('.boot-line');
        bootLines.forEach((line, i) => {
          setTimeout(() => line.classList.add('visible'), i * 150);
        });

        // Progress bar animation
        const progressContainer = document.querySelector('.progress-container');
        const progressFill = document.querySelector('.progress-fill');
        if (progressContainer && progressFill) {
          progressContainer.classList.add('visible');
          let progress = 0;
          const interval = setInterval(() => {
            progress += Math.random() * 15;
            if (progress >= 100) {
              progress = 100;
              clearInterval(interval);
              setTimeout(() => progressContainer.classList.remove('visible'), 500);
            }
            progressFill.style.width = progress + '%';
            progressFill.textContent = Math.floor(progress) + '%';
          }, 100);
        }
      });
    </script>
  </body>
</html>