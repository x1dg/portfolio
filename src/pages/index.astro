---
import Layout from '../layouts/Layout.astro';
import SkillItem from '../components/SkillItem.astro';
import ProjectItem from '../components/ProjectItem.astro';
import ContactLink from '../components/ContactLink.astro';
import SectionHeader from '../components/SectionHeader.astro';
import GalleryItem from '../components/GalleryItem.astro';

const skills = [
  'C#, C++, Python',
  '.NET 6/8 & ASP.NET Core',
  'React',
  'Blazor',
  'Entity Framework Core & Dapper',
  'PostgreSQL / MSSQL / MySQL',
  'Redis',
  'Apache Kafka & RabbitMQ',
  'DDD & CQRS & SAGA & Outbox',
  'Microservices Architecture',
  'Docker & Kubernetes',
  'REST & WebAPI & SignalR',
  'ELK Stack',
  'Grafana & Prometheus',
  'TDD (NUnit/xUnit)',
  'CI/CD (GitHub Actions/Jenkins)',
  'Git',
  'Linux (Ubuntu)',
  'OOP & SOLID',
];

const contacts = [
  { label: 'GITHUB', href: 'https://github.com/x1dg', value: 'github.com/x1dg' },
  { label: 'TELEGRAM', href: 'https://t.me/null_ref_ex', value: '@null_ref_ex' },
  { label: 'EMAIL', href: 'mailto:danilnorm@gmail.com', value: 'danilnorm@gmail.com' },
  { label: 'PHONE', href: 'https://linkedin.com', value: '+7 (912) 653-02-02' },
];
---
<Layout title="Danil Cherdantsev — .NET Backend Developer">

<!-- ASCII Banner -->
<div class="ascii-banner" data-text="DANIL">
██╗  ██╗ ██╗██████╗ ███████╗███████╗██████╗ 
╚██╗██╔╝███║██╔══██╗██╔════╝██╔════╝██╔══██╗
 ╚███╔╝ ╚██║██████╔╝█████╗  █████╗  ██████╔╝
 ██╔██╗  ██║██╔══██╗██╔══╝  ██╔══╝  ██╔══██╗
██╔╝ ██╗ ██║██████╔╝███████╗███████╗██║  ██║
╚═╝  ╚═╝ ╚═╝╚═════╝ ╚══════╝╚══════╝╚═╝  ╚═╝
</div>

<!-- Boot Progress -->
<div class="progress-container">
  <div class="progress-bar">
    <div class="progress-fill">0%</div>
  </div>
</div>

<!-- System Boot -->
<div class="command-output">
  <div class="boot-line"><strong>SYS</strong> [OK] Portfolio v1.0 loaded</div>
  <div class="boot-line"><strong>ROLE</strong> [OK] .NET Backend Developer</div>
  <div class="boot-line"><strong>EXP</strong> [OK] 7+ years in high-load systems</div>
  <div class="boot-line"><strong>STACK</strong> [OK] .NET / C# / RabbitMQ / PostgreSQL</div>
  <div class="boot-line"><strong>STATUS</strong> [OK] Open to opportunities</div>
  <div class="boot-line"><br/>System ready. Scroll to explore.</div>
</div>

<!-- Navigation -->
<nav class="terminal-nav">
  <a href="#about" class="nav-link">~/about</a>
  <a href="#experience" class="nav-link">~/experience</a>
  <a href="#skills" class="nav-link">~/skills</a>
  <a href="#stalker" class="nav-link">~/stalker-mods</a>
  <a href="#gallery" class="nav-link">~/gallery</a>
  <a href="#contact" class="nav-link">~/contact</a>
</nav>

<hr class="section-divider" />

<!-- About -->
<div id="about"></div>
<SectionHeader path="~/about" command=" whoami" />
<div class="command-output">
  <strong>Даниил Черданцев</strong> — Senior .NET Backend Developer из Екатеринбурга<br/>
  7+ лет опыта в FinTech, Insurance и GameDev<br/>
  Специализируюсь на высоконагруженных микросервисных системах<br/>
  GitHub: <a href="https://github.com/x1dg" target="_blank">x1dg</a>
</div>

<SectionHeader path="~/about" command=" cat ./skills.txt" />
<div id="skills"></div>
<div class="skills-list">
  {skills.map(skill => <SkillItem text={skill} />)}
</div>

<SectionHeader path="~/about" command=" cat ./background.txt" />
<div class="command-output">
  Tech Lead @ Smokescope (Fintech, US stock market)<br/>
  Previously: Astrum Entertainment (Warface, 20k CCU)<br/>
  Previously: Сравни.ру (Insurance, 15+ integrations)<br/>
  Previously: КНОПКА & ХОСТ<br/>
  UrFU — Computer Science, 2020<br/>
  English: B2
</div>

<hr class="section-divider" />

<!-- Experience -->
<div id="experience"></div>
<SectionHeader path="~/experience" command=" ls -la" />

<ProjectItem
  name="smokescope/"
  period="[2026 — 2026, 5 months]"
  role="Tech Lead"
  description="Anomaly detection platform for US stock market. .NET 8, Kafka, PostgreSQL, Redis, SignalR, Docker, K8s."
  highlights="Event-driven architecture, SAGA + Outbox, 6x faster releases (2h → 20min), incident detection 15min → 3min"
/>

<ProjectItem
  name="astrum-entertainment/"
  period="[2025 — 2026, 1 year]"
  description=".NET Developer — Warface (online shooter, 20k CCU). .NET 5/8, C++, CryENGINE 3, MySQL, RabbitMQ."
  highlights="API -30% latency, weapon stickers system (99.5% success), matchmaking 45s → 25s, fixed 12 memory leaks (-2.5GB RAM)"
/>

<ProjectItem
  name="sravni.ru/"
  period="[2021 — 2024, 3 years]"
  description=".NET Developer — Insurance platform (OSAGO), 15+ integrations via REST/SOAP. .NET 6/8, PostgreSQL, MSSQL, Redis, RabbitMQ, K8s."
  highlights="Monolith → microservices, CQRS, MSSQL → PostgreSQL (300GB zero downtime), SQL 4s → 450ms, RAM -25% (~300k RUB/mo saved), .NET 3.1→6→8 migration"
/>

<ProjectItem
  name="knopka.com/"
  period="[2020 — 2021, 10 months]"
  description=".NET Developer — Corporate portal (Slack-like). .NET Core 3.1, PostgreSQL, RabbitMQ, Redis, SignalR, Docker, React."
  highlights="Real-time presence (SignalR/Redis), ML.NET + Python FastAPI, CI/CD in Jenkins, jQuery → React+TypeScript"
/>

<ProjectItem
  name="hostco.ru/"
  period="[2018 — 2020, 2 years]"
  description=".NET Programmer — Medical Information System (MIS). .NET Framework 4.x, MSSQL, React, TypeScript, SOAP, TeamCity."
  highlights="Reporting 20-30s → 1-2s (15-20x), appointment booking with OMS/DMS/SMS, jQuery → React migration"
/>

<hr class="section-divider" />

<!-- Key Metrics -->
<SectionHeader path="~/metrics" command=" cat ./achievements.md" />
<div class="command-output metrics-output">
  <strong>6×</strong> Faster releases (2h → 20min) @ Smokescope<br/>
  <strong>30%</strong> API latency reduction @ Warface<br/>
  <strong>99.5%</strong> Success rate for stickers system @ Warface<br/>
  <strong>300k RUB/mo</strong> Cost savings @ Сравни.ру<br/>
  <strong>15-20×</strong> Reporting speedup @ ХОСТ<br/>
  <strong>12</strong> Memory leaks fixed @ Warface (-2.5GB RAM)<br/>
  <strong>150k</strong> Transactions/month @ Сравни.ру<br/>
</div>

<hr class="section-divider" />

<!-- STALKER Mods -->
<div id="stalker"></div>
<SectionHeader path="~/stalker-mods" command=" ls -la" />

<ProjectItem
  name="priboi-story-eternal/"
  period="[2021 — н.в., OGSR Engine]"
  description=`Адаптация легендарного мода "Прибой" на движок OGSR. Полная переработка: новый интерфейс, оружейный пак, анимации, погода.`
  highlights="26 страниц на форуме, 25 подписчиков, активная поддержка"
>
  <div class="mod-extra">
    <div class="mod-label">// Видео-обзоры / Let's Play:</div>
    <div class="project-desc">→ <a href="https://www.youtube.com/@stalker_mods" target="_blank" class="project-link">YouTube канал проекта</a></div>
    <div class="project-desc">→ <a href="https://www.youtube.com/results?search_query=priboi+story+eternal+ogsr" target="_blank" class="project-link">Поиск Let's Play на YouTube</a></div>
  </div>
  <div class="mod-extra">
    <div class="mod-label">// Отзывы с форума:</div>
    <div class="project-desc quote">"Изменения порадовали, так что буду ждать старичка Фотографа" — Maximouse</div>
    <div class="project-desc quote">"Хорошее дело делаете!" — Бурбон</div>
    <div class="project-desc quote">"Вах красавчики, желаю терпения и удачи" — Mervin62</div>
  </div>
  <div class="mod-extra">
    <a href="https://ap-pro.ru/forums/topic/2963-priboi-story-%E2%80%94-eternal-ogsr/" target="_blank" class="project-link">→ ap-pro.ru/forums/topic/2963</a>
  </div>
</ProjectItem>

<ProjectItem
  name="fotograf-selfmade/"
  period="[2022 — н.в., OGSR Engine, в разработке]"
  description=`Глобальное переосмысление мода "Фотограф" на OGSR. Новые квесты, диалоги, интерфейс, оружие на ЗП-руках.`
  highlights="Команда: 1beer, Nimi, Paracetamol, ZonaChe"
>
  <div class="project-desc">→ ~85% готовности, ОБТ вышел 04.11.2022</div>
  <div class="mod-extra">
    <div class="mod-label">// Discord:</div>
    <div class="project-desc">→ <a href="https://discord.gg/9fpMWDmGqk" target="_blank" class="project-link">discord.gg/9fpMWDmGqk</a></div>
  </div>
  <div class="mod-extra">
    <a href="https://ap-pro.ru/forums/topic/3329-fotograf-selfmade/" target="_blank" class="project-link">→ ap-pro.ru/forums/topic/3329</a>
  </div>
</ProjectItem>

<hr class="section-divider" />

<!-- Gallery -->
<div id="gallery"></div>
<SectionHeader path="~/gallery" command=" ls -la ./photos" />
<div class="gallery-grid">
  <GalleryItem src="/about/images/donil.jpg" alt="Danil Cherdantsev" caption="donil.jpg" />
  <GalleryItem src="/about/images/donil2.jpg" alt="Danil Cherdantsev" caption="donil2.jpg" />
  <GalleryItem src="/about/images/donil3.jpg" alt="Danil Cherdantsev" caption="donil3.jpg" />
</div>

<hr class="section-divider" />

<!-- Contact -->
<div id="contact"></div>
<SectionHeader path="~/contact" command=" cat ./links.txt" />
<div class="contact-links">
  {contacts.map(c => <ContactLink label={c.label} href={c.href} value={c.value} />)}
</div>

<hr class="section-divider" />
<p class="eof-line">// End of file. EOF<span class="cursor"></span></p>

</Layout>
